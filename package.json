{
	"name": "fonted",
	"displayName": "fonted",
	"description": "Change UI font for vscode. Just that.",
	"version": "1.2.1",
	"publisher": "degreat",
	"icon": "assets/fonted.png",
	"repository": "https://github.com/blackmann/fonted.git",
	"engines": {
		"vscode": "^1.95.0"
	},
	"categories": ["Other"],
	"activationEvents": ["onStartupFinished"],
	"extensionKind": ["ui"],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "fonted.enable",
				"title": "Fonted: Enable"
			},
			{
				"command": "fonted.disable",
				"title": "Fonted: Disable"
			},
			{
				"command": "fonted.reload",
				"title": "Fonted: Reload"
			},
			{
				"command": "fonted.revert",
				"title": "Fonted: Revert UI"
			}
		],
		"configuration": {
			"type": "object",
			"title": "Fonted",
			"properties": {
				"fonted.font": {
					"type": "string",
					"description": "Font to replace UI font"
				},
				"fonted.fontStretch": {
					"type": "string",
					"description": "font-stretch value"
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "bun run compile",
		"compile": "node ./bundle.mjs",
		"bundle:dev": "node ./bundle.mjs --dev",
		"watch": "tsc -watch -p ./",
		"pretest": "bun run compile && bun run lint",
		"lint": "biome check .",
		"format": "biome format --write .",
		"test": "node ./out/test/runTest.js"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.3",
		"@types/node": "16.x",
		"@types/vscode": "^1.74.0",
		"@vscode/test-electron": "^2.2.0",
		"esbuild": "^0.16.8",
		"typescript": "^4.9.3"
	}
}
