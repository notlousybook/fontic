{
	"name": "fontic",
	"displayName": "Fontic",
	"description": "Change UI Interface font for vscode (yes the editor itself). Just that.",
	"version": "1.2.2",
	"publisher": "notlousybook",
	"icon": "assets/fontic.png",
	"repository": "https://github.com/notlousybook/fontic.git",
	"engines": {
		"vscode": "^1.95.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"extensionKind": [
		"ui"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "fontic.enable",
				"title": "Fontic: Enable"
			},
			{
				"command": "fontic.disable",
				"title": "Fontic: Disable"
			},
			{
				"command": "fontic.reload",
				"title": "Fontic: Reload"
			},
			{
				"command": "fontic.revert",
				"title": "Fontic: Revert UI"
			}
		],
		"configuration": {
			"type": "object",
			"title": "Fontic",
			"properties": {
				"fontic.font": {
					"type": "string",
					"description": "Font to replace UI font"
				},
				"fontic.fontStretch": {
					"type": "string",
					"description": "font-stretch value"
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "bun run compile",
		"compile": "node ./bundle.mjs",
		"bundle:dev": "node ./bundle.mjs --dev",
		"watch": "tsc -watch -p ./",
		"pretest": "bun run compile && bun run lint",
		"lint": "biome check .",
		"format": "biome format --write .",
		"test": "node ./out/test/runTest.js"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.3",
		"@types/node": "16.x",
		"@types/vscode": "^1.74.0",
		"@vscode/test-electron": "^2.2.0",
		"esbuild": "^0.16.8",
		"typescript": "^4.9.3"
	},
	"license": "MIT"
}